<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.financecontroll.controller.BankAccountController"
      stylesheets="@../styles/styles.css">

    <!-- Menu Lateral -->
    <VBox styleClass="sidebar" prefWidth="220" minWidth="220" maxWidth="220" spacing="8">
        <Label text="Finance Control" styleClass="brand-title-small"/>

        <VBox spacing="4" VBox.vgrow="ALWAYS">
            <Button text="🏠  Dashboard" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleDashboard"/>
            <Button text="👤  Perfil" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handlePerfil"/>
            <Button text="🏦  Contas Bancárias" styleClass="sidebar-button-active" maxWidth="Infinity"/>
            <Button fx:id="relatoriosBtn" text="📊  Relatórios" styleClass="sidebar-button-disabled" maxWidth="Infinity"/>
        </VBox>

        <Button text="🚪  Logout" styleClass="sidebar-logout" maxWidth="Infinity" onAction="#handleLogout"/>
    </VBox>

    <!-- Conteúdo Principal -->
    <VBox styleClass="main-content" HBox.hgrow="ALWAYS" spacing="24">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Contas Bancárias" styleClass="form-title"/>
                <Label text="Gerencie suas contas bancárias." styleClass="form-subtitle"/>
            </VBox>
            <Button text="+ Nova Conta" styleClass="primary-button" onAction="#handleNovaConta"/>
        </HBox>

        <!-- Formulário (oculto por padrão) -->
        <VBox fx:id="formPanel" spacing="12" maxWidth="400" managed="false" visible="false">
            <Label text="Nova Conta Bancária" styleClass="section-title"/>
            <VBox spacing="6">
                <Label text="Nome do Banco" styleClass="field-label"/>
                <TextField fx:id="bankNameField" promptText="Ex: Nubank, Inter..." styleClass="input-field" maxWidth="Infinity"/>
            </VBox>
            <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
            <HBox spacing="12">
                <Button text="Salvar" styleClass="primary-button" onAction="#handleSave"/>
                <Button text="Cancelar" styleClass="secondary-button" onAction="#handleCancelar"/>
            </HBox>
        </VBox>

        <!-- Lista de contas -->
        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Label text="Suas contas" styleClass="section-title"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox fx:id="accountList" spacing="8"/>
            </ScrollPane>
        </VBox>

    </VBox>

</HBox>
